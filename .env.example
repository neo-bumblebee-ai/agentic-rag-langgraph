# ── Optional: Web Search ──────────────────────────────────────────────────────
# Get a free key at https://tavily.com
# Without this, the agent skips web search and relies on the vectorstore only.
TAVILY_API_KEY=

# ── Optional: LangSmith Tracing ───────────────────────────────────────────────
# Visualise the full agent graph execution at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-rag-langgraph

# ── Ollama ────────────────────────────────────────────────────────────────────
# Change if Ollama runs on a different host/port
OLLAMA_BASE_URL=http://localhost:11434
